APP_NAME=Revia API
ENVIRONMENT=development
DATABASE_URL=sqlite+pysqlite:///./storage/revia-mvp.db
FILE_STORAGE_ROOT=./storage
STORAGE_BACKEND=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
UPLOAD_URL_EXPIRES_SECONDS=900
DOCUMENT_LEASE_SECONDS=300
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://[::1]:3000"]

APP_ACCESS_CODE=revia-local
SESSION_SIGNING_KEY=replace-with-at-least-32-random-characters
CREDENTIAL_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_PROVIDER=deepseek
AI_MODE=mock
AI_TIMEOUT_SECONDS=60
AI_MAX_OUTPUT_TOKENS=4096
AI_TEMPERATURE=0.1
MATCHING_THRESHOLD=0.35
MATCHING_MAX_CANDIDATES=3

OCR_ENABLED=true
OCR_DPI=144
OCR_MINIMUM_TEXT_LENGTH=8

APP_NAME=Revia API
ENVIRONMENT=development
DATABASE_URL=sqlite+pysqlite:///./storage/revia-mvp.db
FILE_STORAGE_ROOT=./storage
STORAGE_BACKEND=local
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_FORCE_PATH_STYLE=false
UPLOAD_URL_EXPIRES_SECONDS=900
DOCUMENT_LEASE_SECONDS=300
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://[::1]:3000"]

APP_ACCESS_CODE=revia-local
PUBLIC_ACCESS_ENABLED=false
SESSION_SIGNING_KEY=replace-with-at-least-32-random-characters
CREDENTIAL_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_PROVIDER=deepseek
AI_MODE=mock
AI_TIMEOUT_SECONDS=60
AI_MAX_OUTPUT_TOKENS=4096
AI_TEMPERATURE=0.1
MATCHING_THRESHOLD=0.35
MATCHING_MAX_CANDIDATES=3

OCR_ENABLED=true
OCR_DPI=144
OCR_MINIMUM_TEXT_LENGTH=8
OCR_WORKER_MAX_RSS_MB=300
OCR_WORKER_THREADS=1
OCR_WORKER_TIMEOUT_SECONDS=180
MAX_UPLOAD_MB=150
MAX_PDF_PAGES=600
WORKSPACE_MAX_ACTIVE_DOCUMENTS=1
WORKSPACE_ROLLING_24H_PAGE_LIMIT=1200
GLOBAL_MAX_PROCESSING_DOCUMENTS=1
GLOBAL_ROLLING_24H_PAGE_LIMIT=3000

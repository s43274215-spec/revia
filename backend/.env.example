# Optional external OCR on GitHub Actions. Leave all three empty to keep local OCR.
# GITHUB_OCR_TOKEN: fine-grained PAT limited to this repository with Actions: write.
GITHUB_OCR_TOKEN=
GITHUB_OCR_REPOSITORY=s43274215-spec/revia
GITHUB_OCR_WORKFLOW=revia-ocr.yml
GITHUB_OCR_REF=main
# Same random value must be stored as the GitHub repository secret REVIA_OCR_WORKER_KEY.
GITHUB_OCR_WORKER_KEY=
GITHUB_OCR_API_TIMEOUT_SECONDS=30
GITHUB_OCR_LEASE_SECONDS=900
GITHUB_OCR_DOWNLOAD_URL_EXPIRES_SECONDS=900
